### StreamNative license — never commit the real token ###
# Only the *.template is committed; the filled-in secret and raw license keys stay local.
pulsar-operators/configs/00-license-secret.yaml
*sn-license*.key
*-license.key

### Pulsar JWT auth — never commit the signing key or tokens ###
# Generated locally with snctl; recreate the k8s secrets from these (see README).
token-private.key
token-public.key
*.token
